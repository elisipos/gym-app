<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Exercise"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_gravity="center_horizontal"
        android:paddingBottom="12dp"/>

    <TextView
        android:id="@+id/txtViewName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Name" />

    <EditText
        android:id="@+id/inputExerciseName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Bench Press..."
        android:inputType="textPersonName"
        android:padding="8dp" />

    <CheckBox
        android:id="@+id/checkBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Split Exercise" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/splitRepsContainerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="100"
            android:id="@+id/splitRepsTextViewsLayout">

            <TextView
                android:id="@+id/txtViewRepsPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="50"
                android:text="PrimaryReps" />

            <TextView
                android:id="@+id/txtViewRepsSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="50"
                android:text="SecondaryReps" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="100"
            android:id="@+id/splitRepsEditTextsLayout">

            <EditText
                android:id="@+id/inputRepsPrimary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="8..."
                android:inputType="number"
                android:layout_weight="50"/>

            <EditText
                android:id="@+id/inputRepsSecondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint="8..."
                android:inputType="number"
                android:layout_weight="50"/>

        </LinearLayout>

    </LinearLayout>


    <TextView
        android:id="@+id/txtViewWeight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Weight" />

    <EditText
        android:id="@+id/inputWeight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="225..."
        android:inputType="numberDecimal" />

</LinearLayout>
